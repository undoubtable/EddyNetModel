# =========================
# Keep directory structure, ignore contents
# =========================

# data: do not upload dataset files
data/**
!data/**/
!data/**/.gitkeep

# runs: do not upload experiment outputs
runs/**
!runs/
!runs/.gitkeep

# logs: do not upload logs
logs/**
!logs/
!logs/.gitkeep

# outputs/checkpoints/weights
outputs/**
!outputs/
!outputs/.gitkeep

checkpoints/**
!checkpoints/
!checkpoints/.gitkeep

weights/**
!weights/
!weights/.gitkeep

# =========================
# Large files
# =========================
*.npy
*.npz
*.nc
*.h5
*.hdf5
*.mat
*.zarr
*.zip
*.7z
*.tar
*.tar.gz

# Model checkpoints
*.pt
*.pth
*.ckpt
*.onnx

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# System files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
